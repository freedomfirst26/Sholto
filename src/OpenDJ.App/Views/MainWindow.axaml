<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:OpenDJ.App.Controls"
        x:Class="OpenDJ.App.Views.MainWindow"
        Title="OpenDJ"
        Width="1200" Height="700"
        Background="{Binding Theme.BgDeep}">

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="{Binding Theme.SurfaceRaised}"
              Foreground="{Binding Theme.TextBright}">
            <MenuItem Header="Settings">
                <MenuItem Header="Theme">
                    <MenuItem Header="Plasma" Click="OnThemePlasma"/>
                    <MenuItem Header="Classic" Click="OnThemeClassic"/>
                    <MenuItem Header="Serato" Click="OnThemeSerato"/>
                </MenuItem>
                <MenuItem Header="Output device…" Click="OnOutputDeviceClick"/>
            </MenuItem>
        </Menu>

    <Grid RowDefinitions="*,200">

        <!-- Track library, rendered as a fixed-column table. -->
        <Grid Grid.Row="0" RowDefinitions="32,*" Background="{Binding Theme.Surface}">

            <!-- Column header -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="240,*,80,80,80"
                  Background="{Binding Theme.SurfaceRaised}">
                <TextBlock Grid.Column="0" Text="ARTIST"
                           Foreground="{Binding Theme.TextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="12,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="TRACK"
                           Foreground="{Binding Theme.TextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="BPM"
                           Foreground="{Binding Theme.TextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="KEY"
                           Foreground="{Binding Theme.TextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="TIME"
                           Foreground="{Binding Theme.TextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
            </Grid>

            <ListBox Grid.Row="1"
                     Name="TrackList"
                     ItemsSource="{Binding Tracks}"
                     SelectedIndex="{Binding SelectedTrackIndex, Mode=OneWay}"
                     SelectionChanged="OnTrackSelectionChanged"
                     Background="{Binding Theme.Surface}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="240,*,80,80,80">
                            <TextBlock Grid.Column="0" Text="{Binding Artist}"
                                       Foreground="{Binding $parent[Window].DataContext.Theme.TextBright}"
                                       Margin="12,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                       Foreground="{Binding $parent[Window].DataContext.Theme.TextBright}"
                                       Margin="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding BpmDisplay}"
                                       Foreground="{Binding $parent[Window].DataContext.Theme.Accent}"
                                       FontWeight="Bold" Margin="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Key}"
                                       Foreground="{Binding $parent[Window].DataContext.Theme.Primary}"
                                       FontWeight="Bold" Margin="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding DurationDisplay}"
                                       Foreground="{Binding $parent[Window].DataContext.Theme.TextMuted}"
                                       Margin="8,4" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Deck A -->
        <Grid Grid.Row="1" Background="{Binding Theme.SurfaceRaised}" RowDefinitions="48,*">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*" Margin="12,0">
                <TextBlock Grid.Column="0" Text="DECK A"
                           Foreground="{Binding Theme.Primary}"
                           FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <Border Grid.Column="1"
                        Background="{Binding Theme.AccentBg}"
                        CornerRadius="4" Padding="10,3" Margin="16,0,0,0"
                        VerticalAlignment="Center"
                        IsVisible="{Binding DeckA.HasBpm}">
                    <TextBlock Text="{Binding DeckA.BpmDisplay}"
                               Foreground="{Binding $parent[Window].DataContext.Theme.Accent}"
                               FontWeight="Bold" FontSize="18"/>
                </Border>
                <TextBlock Grid.Column="2"
                           Text="{Binding DeckA.LoadedTrack.Title, FallbackValue='click a track to play'}"
                           Foreground="{Binding Theme.TextBright}"
                           VerticalAlignment="Center" Margin="16,0"/>
            </Grid>

            <Panel Grid.Row="1">
                <controls:WaveformControl Peaks="{Binding DeckA.Peaks}"
                                          BeatTimes="{Binding DeckA.BeatTimes}"
                                          DownbeatTimes="{Binding DeckA.DownbeatTimes}"
                                          PlayPosition="{Binding DeckA.PlayPosition}"
                                          Palette="{Binding WaveformPalette}"/>

                <!-- Fade-to-background gradient over the played half. -->
                <Border HorizontalAlignment="Left" Width="600" IsHitTestVisible="False"
                        Background="{Binding Theme.PlayedFadeGradient}"/>

                <!-- Disc cluster: vinyl + rotating needle + title/artist on the side. -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Left" VerticalAlignment="Center"
                            Margin="20,0,0,0" Spacing="16"
                            IsHitTestVisible="False">

                    <!-- Vinyl disc with rotation tied to BPM. -->
                    <Grid Width="140" Height="140">
                        <!-- Outer progress ring: green → yellow → orange → red.
                             Wrapped in a Border whose Opacity flashes when IsNearEnd. -->
                        <Border Name="DiscRing" Width="140" Height="140">
                            <Ellipse Width="140" Height="140"
                                     Fill="{Binding Theme.BgDeep}"
                                     Stroke="{Binding DeckA.DiscRingBrush}"
                                     StrokeThickness="3"/>
                        </Border>
                        <Ellipse Width="124" Height="124" Stroke="{Binding Theme.Border}" StrokeThickness="1"/>
                        <Ellipse Width="108" Height="108" Stroke="{Binding Theme.Border}" StrokeThickness="1"/>
                        <Ellipse Width="92"  Height="92"  Stroke="{Binding Theme.Border}" StrokeThickness="1"/>

                        <Ellipse Width="80" Height="80"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"
                                 Fill="{Binding Theme.AlbumArtBrush}"/>

                        <!-- Rotation needle -->
                        <Border Width="140" Height="140"
                                RenderTransformOrigin="0.5,0.5"
                                Background="Transparent">
                            <Border.RenderTransform>
                                <RotateTransform Angle="{Binding DeckA.DiscAngle}" CenterX="70" CenterY="70"/>
                            </Border.RenderTransform>
                            <Rectangle Width="2" Height="60"
                                       Fill="{Binding $parent[Window].DataContext.Theme.Mint}"
                                       HorizontalAlignment="Center" VerticalAlignment="Top"
                                       Margin="0,10,0,0"/>
                        </Border>

                        <Ellipse Width="6" Height="6" Fill="{Binding Theme.BgDeep}"
                                 HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Track title + artist, larger, beside the disc. -->
                    <StackPanel VerticalAlignment="Center" Spacing="4" MaxWidth="320">
                        <TextBlock Text="{Binding DeckA.LoadedTrack.Title, FallbackValue=''}"
                                   FontSize="22" FontWeight="Bold"
                                   Foreground="{Binding Theme.TextBright}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding DeckA.LoadedTrack.Artist, FallbackValue=''}"
                                   FontSize="14"
                                   Foreground="{Binding Theme.TextMuted}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </StackPanel>
            </Panel>
        </Grid>

    </Grid>
    </DockPanel>
</Window>
