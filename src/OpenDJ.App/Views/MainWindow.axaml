<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenDJ.App.ViewModels"
        xmlns:lib="using:OpenDJ.Library"
        xmlns:controls="using:OpenDJ.App.Controls"
        x:Class="OpenDJ.App.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="OpenDJ"
        Width="1200" Height="700"
        Background="#111111">

    <Grid RowDefinitions="*,200">

        <!-- Track library -->
        <ListBox Grid.Row="0"
                 ItemsSource="{Binding Tracks}"
                 SelectedIndex="{Binding SelectedTrackIndex}"
                 Background="#1A1A1A">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="lib:Track">
                    <Grid ColumnDefinitions="*,200,100">
                        <TextBlock Grid.Column="0" Text="{Binding Title}"
                                   Foreground="White" Margin="8,4"/>
                        <TextBlock Grid.Column="1" Text="{Binding Artist}"
                                   Foreground="#888888" Margin="8,4"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Duration, StringFormat=\{0:mm\\:ss\}}"
                                   Foreground="#555555" Margin="8,4"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Deck A -->
        <Grid Grid.Row="1" Background="#1E1E1E" RowDefinitions="48,*">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Margin="12,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                            VerticalAlignment="Center">
                    <TextBlock Text="DECK A" Foreground="#00FFCC"
                               FontWeight="Bold" FontSize="14"/>
                    <Button Name="PlayButton"
                            Content="PLAY"
                            Click="OnPlayButtonClick"
                            Background="#333333" Foreground="White"
                            Width="80" Height="32"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="{Binding DeckA.LoadedTrack.Title, FallbackValue='— no track loaded —'}"
                           Foreground="#CCCCCC" VerticalAlignment="Center" Margin="16,0"/>
            </Grid>

            <controls:WaveformControl Grid.Row="1"
                                      Peaks="{Binding DeckA.Peaks}"
                                      PlayPosition="{Binding DeckA.PlayPosition}"/>
        </Grid>

    </Grid>
</Window>
