<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:OpenDJ.App.Controls"
        x:Class="OpenDJ.App.Views.MainWindow"
        Title="OpenDJ"
        Width="1200" Height="700"
        Background="#111111">

    <DockPanel>
        <Menu DockPanel.Dock="Top" Background="#222222">
            <MenuItem Header="Settings">
                <MenuItem Header="Output device…" Click="OnOutputDeviceClick"/>
                <MenuItem Header="Waveform colors">
                    <MenuItem Header="Rekordbox (blue / white / yellow)" Click="OnPaletteBands"/>
                    <MenuItem Header="Serato (red / green / blue)" Click="OnPaletteHot"/>
                </MenuItem>
            </MenuItem>
        </Menu>

    <Grid RowDefinitions="*,200">

        <!-- Track library -->
        <ListBox Grid.Row="0"
                 Name="TrackList"
                 ItemsSource="{Binding Tracks}"
                 SelectedIndex="{Binding SelectedTrackIndex, Mode=OneWay}"
                 SelectionChanged="OnTrackSelectionChanged"
                 Background="#1A1A1A">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid ColumnDefinitions="*,200,100">
                        <TextBlock Grid.Column="0" Text="{Binding Title}"
                                   Foreground="White" Margin="8,4"/>
                        <TextBlock Grid.Column="1" Text="{Binding Artist}"
                                   Foreground="#AAAAAA" Margin="8,4"/>
                        <TextBlock Grid.Column="2"
                                   Text="{Binding Duration, StringFormat=\{0:mm\\:ss\}}"
                                   Foreground="#777777" Margin="8,4"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <!-- Deck A -->
        <Grid Grid.Row="1" Background="#2A2A2A" RowDefinitions="48,*">

            <Grid Grid.Row="0" ColumnDefinitions="Auto,Auto,*" Margin="12,0">
                <TextBlock Grid.Column="0" Text="DECK A" Foreground="#00FFCC"
                           FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding DeckA.BpmDisplay}"
                           Foreground="#FFCC00" FontWeight="Bold" FontSize="14"
                           VerticalAlignment="Center" Margin="16,0,0,0"/>
                <TextBlock Grid.Column="2"
                           Text="{Binding DeckA.LoadedTrack.Title, FallbackValue='click a track to play'}"
                           Foreground="#CCCCCC" VerticalAlignment="Center" Margin="16,0"/>
            </Grid>

            <controls:WaveformControl Grid.Row="1"
                                      Peaks="{Binding DeckA.Analysis.Basic.Peaks}"
                                      BeatTimes="{Binding DeckA.Analysis.Basic.BeatTimes}"
                                      PlayPosition="{Binding DeckA.PlayPosition}"
                                      Palette="{Binding WaveformPalette}"/>
        </Grid>

    </Grid>
    </DockPanel>
</Window>
