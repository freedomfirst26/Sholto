<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:OpenDJ.App.Controls"
        xmlns:v="using:OpenDJ.App.Views"
        xmlns:media="using:Avalonia.Media"
        x:Class="OpenDJ.App.Views.MainWindow"
        Title="OpenDJ"
        Width="1200" Height="900"
        Background="{DynamicResource OpenDjBgDeep}">

    <Window.Resources>
        <!-- Default-theme brushes; overridden at runtime in MainWindow.axaml.cs when the
             user switches themes. Use {DynamicResource OpenDj…} in templates so colour
             updates flow without going through $parent traversal (which goes stale on
             menu/hover state changes under the Fluent theme). -->
        <SolidColorBrush x:Key="OpenDjBgDeep"        Color="#0B0918"/>
        <SolidColorBrush x:Key="OpenDjSurface"       Color="#16122B"/>
        <SolidColorBrush x:Key="OpenDjSurfaceRaised" Color="#1F1A3D"/>
        <SolidColorBrush x:Key="OpenDjBorder"        Color="#2D2752"/>
        <SolidColorBrush x:Key="OpenDjPrimary"       Color="#7C5CFF"/>
        <SolidColorBrush x:Key="OpenDjAccent"        Color="#FF4E9A"/>
        <SolidColorBrush x:Key="OpenDjAccentBg"      Color="#33FF4E9A"/>
        <SolidColorBrush x:Key="OpenDjMint"          Color="#34F0C6"/>
        <SolidColorBrush x:Key="OpenDjTextBright"    Color="#EEEAFF"/>
        <SolidColorBrush x:Key="OpenDjTextMuted"     Color="#8B7FB8"/>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top"
              Background="{DynamicResource OpenDjSurfaceRaised}"
              Foreground="{DynamicResource OpenDjTextBright}">
            <MenuItem Header="Settings">
                <MenuItem Header="Theme">
                    <MenuItem Header="Plasma" Click="OnThemePlasma"/>
                    <MenuItem Header="Classic" Click="OnThemeClassic"/>
                    <MenuItem Header="Serato" Click="OnThemeSerato"/>
                </MenuItem>
                <MenuItem Header="Output device…" Click="OnOutputDeviceClick"/>
            </MenuItem>
        </Menu>

    <Grid RowDefinitions="*,200,200">

        <!-- Track library, rendered as a fixed-column table. -->
        <Grid Grid.Row="0" RowDefinitions="32,*" Background="{DynamicResource OpenDjSurface}">

            <!-- Column header -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="240,*,80,80,80"
                  Background="{DynamicResource OpenDjSurfaceRaised}">
                <TextBlock Grid.Column="0" Text="ARTIST"
                           Foreground="{DynamicResource OpenDjTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="12,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="TRACK"
                           Foreground="{DynamicResource OpenDjTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="BPM"
                           Foreground="{DynamicResource OpenDjTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="KEY"
                           Foreground="{DynamicResource OpenDjTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="TIME"
                           Foreground="{DynamicResource OpenDjTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
            </Grid>

            <ListBox Grid.Row="1"
                     Name="TrackList"
                     ItemsSource="{Binding Tracks}"
                     SelectedIndex="{Binding SelectedTrackIndex, Mode=OneWay}"
                     SelectionChanged="OnTrackSelectionChanged"
                     Background="{DynamicResource OpenDjSurface}">
                <ListBox.Styles>
                    <!-- Override Fluent's hover/selected backgrounds so they don't clobber
                         our row foreground colors after the pointer leaves. -->
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource OpenDjSurfaceRaised}"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource OpenDjAccentBg}"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="240,*,80,80,80">
                            <TextBlock Grid.Column="0" Text="{Binding Artist}"
                                       Foreground="{DynamicResource OpenDjTextBright}"
                                       Margin="12,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding Title}"
                                       Foreground="{DynamicResource OpenDjTextBright}"
                                       Margin="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding BpmDisplay}"
                                       Foreground="{DynamicResource OpenDjAccent}"
                                       FontWeight="Bold" Margin="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding Key}"
                                       Foreground="{DynamicResource OpenDjPrimary}"
                                       FontWeight="Bold" Margin="8,4" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="{Binding DurationDisplay}"
                                       Foreground="{DynamicResource OpenDjTextMuted}"
                                       Margin="8,4" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <v:DeckView Grid.Row="1" DataContext="{Binding Deck1}"/>
        <v:DeckView Grid.Row="2" DataContext="{Binding Deck2}"/>

    </Grid>
    </DockPanel>
</Window>
