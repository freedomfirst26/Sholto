<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="OpenDJ.App.Views.AudioDevicePicker"
        Title="Choose Audio Output"
        Width="500" Height="400"
        WindowStartupLocation="CenterOwner"
        Background="#1A1A1A"
        CanResize="False">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">

        <TextBlock Grid.Row="0"
                   Text="Select an audio output device:"
                   Foreground="White" FontSize="14"
                   Margin="0,0,0,12"/>

        <ListBox Grid.Row="1"
                 Name="DeviceList"
                 Background="#111111"
                 Foreground="White">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="4">
                        <TextBlock Text="{Binding Name}" Foreground="White"/>
                        <TextBlock Text="default" IsVisible="{Binding IsDefault}"
                                   Foreground="#00FFCC" FontSize="11"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="0,12,0,0" Spacing="8">
            <Button Content="Cancel" Click="OnCancel"
                    Background="#333333" Foreground="White" Padding="16,6"/>
            <Button Content="Use this device" Click="OnConfirm"
                    Background="#00AAAA" Foreground="Black" Padding="16,6" FontWeight="Bold"/>
        </StackPanel>
    </Grid>
</Window>
