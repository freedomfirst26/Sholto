<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:CommunityDj.App.Controls"
             x:Class="CommunityDj.App.Views.DeckView"
             x:Name="Root">

    <Grid Background="{DynamicResource CommunityDjSurfaceRaised}">

        <Panel>
            <controls:WaveformControl Peaks="{Binding Peaks}"
                                      BeatTimes="{Binding BeatTimes}"
                                      DownbeatTimes="{Binding DownbeatTimes}"
                                      PlayPosition="{Binding PlayPosition}"
                                      GainOverlay="{Binding EffectiveGain}"
                                      MagneticGlowSec="{Binding MagneticGlowSec}"
                                      IsScrubbing="{Binding IsScrubbing}"
                                      Palette="{Binding $parent[Window].DataContext.WaveformPalette}"/>

            <!-- Fade-to-background over the played half. -->
            <Border HorizontalAlignment="Left" Width="600" IsHitTestVisible="False"
                    Background="{Binding $parent[Window].DataContext.Theme.PlayedFadeGradient}"/>

            <!-- Mute tint: full-deck red wash whenever EffectiveGain is 0 (channel fader
                 fully down or crossfader fully on the other deck). Sits above the
                 waveform but below the disc/title cluster so the indicators stay legible. -->
            <Border IsHitTestVisible="False"
                    Background="#FF3D4E" Opacity="0.18"
                    IsVisible="{Binding IsMuted}"/>

            <!-- Disc + title cluster -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="20,0,0,0" Spacing="16"
                        IsHitTestVisible="False">

                <StackPanel Orientation="Vertical" Spacing="6">
                <Grid Width="140" Height="140">
                    <!-- Outer ring: colour by progress, opacity flashes near the end. -->
                    <Border Name="DiscRing" Width="140" Height="140">
                        <Ellipse Width="140" Height="140"
                                 Fill="{DynamicResource CommunityDjBgDeep}"
                                 Stroke="{Binding DiscRingBrush}"
                                 StrokeThickness="3"/>
                    </Border>
                    <Ellipse Width="124" Height="124" Stroke="{DynamicResource CommunityDjBorder}" StrokeThickness="1"/>
                    <Ellipse Width="108" Height="108" Stroke="{DynamicResource CommunityDjBorder}" StrokeThickness="1"/>
                    <Ellipse Width="92"  Height="92"  Stroke="{DynamicResource CommunityDjBorder}" StrokeThickness="1"/>

                    <!-- Needle (behind the album art so only the outer stub pokes out) -->
                    <Border Width="140" Height="140"
                            RenderTransformOrigin="0.5,0.5"
                            Background="Transparent">
                        <Border.RenderTransform>
                            <RotateTransform Angle="{Binding DiscAngle}" CenterX="70" CenterY="70"/>
                        </Border.RenderTransform>
                        <Rectangle Width="2" Height="60"
                                   Fill="{DynamicResource CommunityDjMint}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Margin="0,10,0,0"/>
                    </Border>

                    <Ellipse Width="80" Height="80"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Fill="{Binding $parent[Window].DataContext.Theme.AlbumArtBrush}"/>

                    <TextBlock Text="{Binding BpmDisplayShort}"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource CommunityDjTextBright}"
                               Opacity="0.55"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               IsVisible="{Binding HasBpm}"/>

                </Grid>

                <!-- Stem labels below the disc as right-leaning parallelogram chips.
                     Filled-color when the stem is active, hollow + colored text when muted.
                     Mirrors the arcs above; same color codes.  -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center">
                    <Grid Width="42" Height="16">
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Fill="#3D8BFF" Stroke="#3D8BFF" StrokeThickness="1"
                              IsVisible="{Binding DrumsActive}"/>
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Stroke="#3D8BFF" StrokeThickness="1"
                              IsVisible="{Binding !DrumsActive}"/>
                        <TextBlock Text="DRMS" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="Black" IsVisible="{Binding DrumsActive}"/>
                        <TextBlock Text="DRMS" FontSize="9" FontWeight="Bold" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#3D8BFF" IsVisible="{Binding !DrumsActive}"/>
                    </Grid>
                    <Grid Width="42" Height="16">
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Fill="#34F06F" Stroke="#34F06F" StrokeThickness="1"
                              IsVisible="{Binding VocalsActive}"/>
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Stroke="#34F06F" StrokeThickness="1"
                              IsVisible="{Binding !VocalsActive}"/>
                        <TextBlock Text="VOX" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="Black" IsVisible="{Binding VocalsActive}"/>
                        <TextBlock Text="VOX" FontSize="9" FontWeight="Bold" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#34F06F" IsVisible="{Binding !VocalsActive}"/>
                    </Grid>
                    <Grid Width="42" Height="16">
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Fill="#FF4E5E" Stroke="#FF4E5E" StrokeThickness="1"
                              IsVisible="{Binding InstrumentalActive}"/>
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Stroke="#FF4E5E" StrokeThickness="1"
                              IsVisible="{Binding !InstrumentalActive}"/>
                        <TextBlock Text="INST" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="Black" IsVisible="{Binding InstrumentalActive}"/>
                        <TextBlock Text="INST" FontSize="9" FontWeight="Bold" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#FF4E5E" IsVisible="{Binding !InstrumentalActive}"/>
                    </Grid>
                </StackPanel>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Spacing="4" MaxWidth="320">
                    <TextBlock Text="{Binding LoadedTrack.Title, FallbackValue=''}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource CommunityDjTextBright}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding LoadedTrack.Artist, FallbackValue=''}"
                               FontSize="14"
                               Foreground="{DynamicResource CommunityDjTextMuted}"
                               TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </StackPanel>
        </Panel>
    </Grid>
</UserControl>
