<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Sholto.App.Controls"
        xmlns:v="using:Sholto.App.Views"
        xmlns:media="using:Avalonia.Media"
        x:Class="Sholto.App.Views.MainWindow"
        Title="Sholto"
        Width="1200" Height="900"
        Background="{DynamicResource SholtoBgDeep}">

    <Window.Resources>
        <!-- Default-theme brushes; overridden at runtime in MainWindow.axaml.cs when the
             user switches themes. Use {DynamicResource Sholto…} in templates so colour
             updates flow without going through $parent traversal (which goes stale on
             menu/hover state changes under the Fluent theme). -->
        <SolidColorBrush x:Key="SholtoBgDeep"        Color="#0B0918"/>
        <SolidColorBrush x:Key="SholtoSurface"       Color="#16122B"/>
        <SolidColorBrush x:Key="SholtoSurfaceRaised" Color="#1F1A3D"/>
        <SolidColorBrush x:Key="SholtoBorder"        Color="#2D2752"/>
        <SolidColorBrush x:Key="SholtoPrimary"       Color="#7C5CFF"/>
        <SolidColorBrush x:Key="SholtoAccent"        Color="#FF4E9A"/>
        <SolidColorBrush x:Key="SholtoAccentBg"      Color="#33FF4E9A"/>
        <SolidColorBrush x:Key="SholtoMint"          Color="#34F0C6"/>
        <SolidColorBrush x:Key="SholtoTextBright"    Color="#EEEAFF"/>
        <SolidColorBrush x:Key="SholtoTextMuted"     Color="#8B7FB8"/>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- Top bar: Menu on the left, optional CPU/RAM readout on the right (visible
             only when SHOLTO_DEBUG_STATS=1 has been set on launch). Both share the
             SurfaceRaised background so the bar reads as a single strip. -->
        <DockPanel DockPanel.Dock="Top"
                   Background="{DynamicResource SholtoSurfaceRaised}">
            <TextBlock DockPanel.Dock="Right"
                       Text="{Binding DebugStats}"
                       IsVisible="{Binding DebugStatsVisible}"
                       FontFamily="monospace" FontSize="11"
                       Foreground="{DynamicResource SholtoTextMuted}"
                       VerticalAlignment="Center"
                       Margin="0,0,12,0"/>
        <Menu Background="Transparent"
              Foreground="{DynamicResource SholtoTextBright}">
            <MenuItem Header="Settings">
                <MenuItem Header="Theme">
                    <MenuItem Header="Classic" Click="OnThemeClassic"/>
                    <MenuItem Header="Serato" Click="OnThemeSerato"/>
                    <MenuItem Header="Front Line Assembly" Click="OnThemeFrontLineAssembly"/>
                    <MenuItem Header="Silence Groove" Click="OnThemeSilenceGroove"/>
                    <MenuItem Header="Jeremy Soule" Click="OnThemeJeremySoule"/>
                    <MenuItem Header="Drab Majesty" Click="OnThemeDrabMajesty"/>
                    <MenuItem Header="Sub Focus" Click="OnThemeSubFocus"/>
                    <MenuItem Header="Type O Negative" Click="OnThemeTypeONegative"/>
                    <MenuItem Header="Birthday Massacre" Click="OnThemeBirthdayMassacre"/>
                    <MenuItem Header="Boards of Canada" Click="OnThemeBoardsOfCanada"/>
                    <MenuItem Header="Pantera" Click="OnThemePantera"/>
                </MenuItem>
                <MenuItem Header="Music folder…" Click="OnMusicFolderClick"/>
                <MenuItem Header="Output device…" Click="OnOutputDeviceClick"/>
            </MenuItem>
        </Menu>
        </DockPanel>

    <Grid RowDefinitions="*,8,200,200">

        <!-- Track library, rendered as a fixed-column table. -->
        <Grid Grid.Row="0" RowDefinitions="32,*" Background="{DynamicResource SholtoSurface}">

            <!-- Column header -->
            <Grid Grid.Row="0"
                  ColumnDefinitions="80,240,*,80,80,80"
                  Background="{DynamicResource SholtoSurfaceRaised}">
                <TextBlock Grid.Column="0" Text="ANALYZED"
                           Foreground="{DynamicResource SholtoTextMuted}" FontWeight="Bold" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="ARTIST"
                           Foreground="{DynamicResource SholtoTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="12,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="TRACK"
                           Foreground="{DynamicResource SholtoTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="BPM"
                           Foreground="{DynamicResource SholtoTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="4" Text="KEY"
                           Foreground="{DynamicResource SholtoTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="5" Text="TIME"
                           Foreground="{DynamicResource SholtoTextMuted}" FontWeight="Bold" FontSize="11"
                           Margin="8,8" VerticalAlignment="Center"/>
            </Grid>

            <!-- Library-unreachable banner. Pops in when a music dir is saved but
                 the path doesn't exist on disk right now (typical cause: the
                 external drive that holds the user's library wasn't mounted at
                 app launch). Banner offers a "Choose folder…" button that runs
                 the same picker as the View menu's "Change Music Folder…" entry.
                 Sits in Row 1 so it overlays the empty track-list area; hidden
                 once a successful scan completes. -->
            <Border Grid.Row="1"
                    IsVisible="{Binding LibraryUnreachableVisible}"
                    HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource SholtoSurfaceRaised}"
                    BorderBrush="{DynamicResource SholtoBorder}" BorderThickness="1"
                    CornerRadius="8" Padding="20,16" MaxWidth="520">
                <StackPanel Spacing="10">
                    <TextBlock Text="Music library not reachable"
                               Foreground="{DynamicResource SholtoAccent}"
                               FontWeight="Bold" FontSize="15"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding LibraryUnreachablePath}"
                               Foreground="{DynamicResource SholtoTextBright}"
                               FontFamily="monospace" FontSize="12"
                               TextWrapping="Wrap" HorizontalAlignment="Center"/>
                    <TextBlock Text="The saved path doesn't exist right now — usually because an external drive hasn't mounted yet. Mount the drive and relaunch, or pick a different folder."
                               Foreground="{DynamicResource SholtoTextMuted}"
                               FontSize="12"
                               TextWrapping="Wrap" HorizontalAlignment="Center"
                               MaxWidth="460"/>
                    <Button Content="Choose folder…"
                            Click="OnMusicFolderClick"
                            HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <ListBox Grid.Row="1"
                     Name="TrackList"
                     ItemsSource="{Binding Tracks}"
                     SelectedIndex="{Binding SelectedTrackIndex, Mode=TwoWay}"
                     SelectionChanged="OnTrackSelectionChanged"
                     Background="{DynamicResource SholtoSurface}">
                <ListBox.Styles>
                    <!-- Override Fluent's hover/selected backgrounds so they don't clobber
                         our row foreground colors after the pointer leaves. -->
                    <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Background" Value="Transparent"/>
                    </Style>
                    <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SholtoSurfaceRaised}"/>
                    </Style>
                    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SholtoAccentBg}"/>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="80,240,*,80,80,80">
                            <Grid Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <!-- Done state — uses the theme accent so it reads as a positive
                                     signal and changes colour with each theme. -->
                                <TextBlock Text="✓"
                                           Foreground="{DynamicResource SholtoAccent}"
                                           FontSize="13" FontWeight="Bold"
                                           IsVisible="{Binding Analyzed}"/>
                                <!-- Running state: indeterminate progress bar. Avalonia's
                                     built-in animation, no fragile custom animators.
                                     MinWidth=0 stops the default 100-px minimum from
                                     bleeding into the artist column. -->
                                <!-- IsIndeterminate is also bound — leaving it True
                                     keeps a hidden animation timer running on every
                                     hidden row (~90 of them at idle = catastrophic
                                     UI-thread invalidation). Only ticks when this row
                                     is actually analysing. -->
                                <ProgressBar Width="28" Height="4"
                                             MinWidth="0"
                                             IsIndeterminate="{Binding IsAnalyzing}"
                                             ShowProgressText="False"
                                             HorizontalAlignment="Center"
                                             Background="Transparent"
                                             Foreground="{DynamicResource SholtoAccent}"
                                             IsVisible="{Binding IsAnalyzing}"/>
                            </Grid>
                            <!-- Played tracks render italic. Style class applied to both
                                 artist and title cells so they shift together as one signal. -->
                            <TextBlock Grid.Column="1" Text="{Binding Artist}"
                                       Foreground="{DynamicResource SholtoTextBright}"
                                       Margin="12,4" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Classes.played="{Binding IsPlayed}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock.played">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <!-- Mute the title/artist so unplayed rows visually pop;
                                             keeps the row readable but flags "out of the running". -->
                                        <Setter Property="Foreground" Value="{DynamicResource SholtoTextMuted}"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <TextBlock Grid.Column="2" Text="{Binding Title}"
                                       Foreground="{DynamicResource SholtoTextBright}"
                                       Margin="8,4" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis"
                                       Classes.played="{Binding IsPlayed}">
                                <TextBlock.Styles>
                                    <Style Selector="TextBlock.played">
                                        <Setter Property="FontStyle" Value="Italic"/>
                                        <Setter Property="FontWeight" Value="Bold"/>
                                        <!-- Mute the title/artist so unplayed rows visually pop;
                                             keeps the row readable but flags "out of the running". -->
                                        <Setter Property="Foreground" Value="{DynamicResource SholtoTextMuted}"/>
                                    </Style>
                                </TextBlock.Styles>
                            </TextBlock>
                            <TextBlock Grid.Column="3" Text="{Binding BpmDisplay}"
                                       Foreground="{DynamicResource SholtoAccent}"
                                       FontWeight="Bold" Margin="8,4" VerticalAlignment="Center"/>
                            <!-- Camelot key chip — matches the deck panel so the same colour
                                 shows in both surfaces. Hidden when no key is analysed yet.
                                 Chips for harmonically-eligible keys gain a primary-colour
                                 outline; non-eligible chips stay readable at full opacity. -->
                            <Border Grid.Column="4" CornerRadius="4" Padding="6,1"
                                    Background="{Binding KeyBrush}"
                                    HorizontalAlignment="Left" VerticalAlignment="Center"
                                    Margin="8,4"
                                    Classes="key-chip"
                                    Classes.eligible="{Binding KeyEligible}"
                                    IsVisible="{Binding Key, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                <Border.Styles>
                                    <Style Selector="Border.key-chip">
                                        <Setter Property="BorderThickness" Value="0"/>
                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                        <Setter Property="BoxShadow" Value="0 0 0 0 Transparent"/>
                                    </Style>
                                    <!-- Eligible chips get a bright white outline + soft white
                                         outer glow. Hardcoded white instead of the theme's
                                         Primary so the "this key mixes" signal reads identically
                                         across every theme (Primary blends with similar-hue
                                         chip backgrounds in some themes). -->
                                    <Style Selector="Border.key-chip.eligible">
                                        <Setter Property="BorderThickness" Value="2"/>
                                        <Setter Property="BorderBrush" Value="White"/>
                                        <Setter Property="BoxShadow" Value="0 0 6 1 #B0FFFFFF"/>
                                    </Style>
                                </Border.Styles>
                                <TextBlock Text="{Binding Key}"
                                           Foreground="White"
                                           FontWeight="Bold" FontSize="12"/>
                            </Border>
                            <TextBlock Grid.Column="5" Text="{Binding DurationDisplay}"
                                       Foreground="{DynamicResource SholtoTextMuted}"
                                       Margin="8,4" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- Brand watermark + wooden-blinds texture overlay, both scale with the
             window. ClipToBounds keeps the rotated stripes inside the track-list
             area, IsHitTestVisible=False so nothing here steals clicks. -->
        <Grid Grid.Row="0" IsHitTestVisible="False" ClipToBounds="True">
            <!-- The S logo, scaled to fill ~60% of the track-list area via a
                 Viewbox + a Border that constrains aspect. Grows naturally as
                 the window resizes. -->
            <Viewbox Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"
                     Margin="40,40,40,60">
                <Grid Width="96" Height="96" Opacity="0.18">
                    <TextBlock Text="S" FontFamily="Inter, Helvetica, Arial" FontWeight="ExtraBold"
                               FontSize="84" Foreground="#3D8BFF"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="-8,4,0,0"/>
                    <TextBlock Text="S" FontFamily="Inter, Helvetica, Arial" FontWeight="ExtraBold"
                               FontSize="84" Foreground="#34F06F"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <TextBlock Text="S" FontFamily="Inter, Helvetica, Arial" FontWeight="ExtraBold"
                               FontSize="84" Foreground="#FF4E5E"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="8,-4,0,0"/>
                </Grid>
            </Viewbox>

            <!-- Angled wooden-blinds texture, sits in front of the S at low
                 opacity for a venetian-blind feel. SpreadMethod=Repeat gives us
                 unlimited stripes; the RotateTransform tilts them ~22°. The
                 rectangle is oversized so the rotated corners still fill bounds. -->
            <Rectangle Width="3000" Height="3000" Opacity="0.03"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       RenderTransformOrigin="50%,50%">
                <Rectangle.Fill>
                    <!-- Stripe period = 0.012 of the 3000 px rectangle = 36 px.
                         SpreadMethod=Repeat tiles the gradient outward. -->
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,1.2%"
                                         SpreadMethod="Repeat">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#FFFFFF" Offset="0.35"/>
                        <GradientStop Color="#00000000" Offset="0.36"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Rectangle.Fill>
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="8"/>
                </Rectangle.RenderTransform>
            </Rectangle>
        </Grid>

        <!-- Drop shadow cast by the top of Deck 1 onto the bottom of the track list.
             Lives in the list's row (0) but anchored to its bottom edge, so the
             gradient extends *into* the list. Dark at the bottom (where the deck
             meets the list), fading transparent upward. -->
        <Border Grid.Row="0" VerticalAlignment="Bottom" Height="32"
                IsHitTestVisible="False">
            <Border.Background>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Color="#00000000" Offset="0.0"/>
                    <GradientStop Color="#B0000000" Offset="1.0"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <v:DeckView Grid.Row="2" DataContext="{Binding Deck1}"/>
        <v:DeckView Grid.Row="3" DataContext="{Binding Deck2}"/>

        <!-- Magnet-lock eligibility indicator. Sits in the gap between the two
             vinyl discs (left-aligned with horizontal margin matching the vinyl
             centre at x=90). Vertically centered across both deck rows so it
             lands exactly between the two vinyls.
             Pops in when both decks are analysed, both are playing, and their
             playback BPMs are within 0.5%. Animation: opacity 0→1 + scale
             0.4→1.0 with ease-out bounce. IsHitTestVisible=False so it never
             eats clicks meant for the deck. -->
        <Border Grid.Row="2" Grid.RowSpan="2"
                HorizontalAlignment="Left" VerticalAlignment="Center"
                Margin="80,0,0,0"
                Width="20" Height="20"
                RenderTransformOrigin="50%,50%"
                IsHitTestVisible="False"
                Classes="magnet"
                Classes.eligible="{Binding IsMagnetEligible}">
            <Border.Styles>
                <Style Selector="Border.magnet">
                    <Setter Property="Opacity" Value="0"/>
                    <Setter Property="RenderTransform" Value="scale(0.4)"/>
                </Style>
                <Style Selector="Border.magnet.eligible">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="RenderTransform" Value="scale(1)"/>
                </Style>
            </Border.Styles>
            <Border.Transitions>
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.35" Easing="BackEaseOut"/>
                </Transitions>
            </Border.Transitions>
            <!-- Material Design "link" icon at 24×24, scaled into the 40×40
                 viewbox via Viewbox/Stretch. Two interlocked C-shapes joined by
                 a horizontal bar — the universal "chain link / linked" glyph.
                 Drop shadow gives the green chip a little lift off the dark
                 backdrop so it pops against the waveform when active. -->
            <Viewbox Stretch="Uniform">
                <Canvas Width="24" Height="24">
                    <Path Fill="#34F06F"
                          Data="M 3.9 12 C 3.9 10.29 5.29 8.9 7 8.9 H 11 V 7 H 7 C 4.24 7 2 9.24 2 12 C 2 14.76 4.24 17 7 17 H 11 V 15.1 H 7 C 5.29 15.1 3.9 13.71 3.9 12 Z M 8 13 H 16 V 11 H 8 V 13 Z M 17 7 H 13 V 8.9 H 17 C 18.71 8.9 20.1 10.29 20.1 12 C 20.1 13.71 18.71 15.1 17 15.1 H 13 V 17 H 17 C 19.76 17 22 14.76 22 12 C 22 9.24 19.76 7 17 7 Z"/>
                </Canvas>
            </Viewbox>
        </Border>

    </Grid>
    </DockPanel>

    <!-- Spacebar search overlay. Sibling of DockPanel inside the top-level
         Grid so it z-orders ABOVE the entire app when its IsVisible flips on. -->
    <v:SearchOverlay/>
    </Grid>
</Window>
