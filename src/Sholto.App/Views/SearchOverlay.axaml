<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Sholto.App.ViewModels"
             xmlns:converters="using:Avalonia.Data.Converters"
             x:Class="Sholto.App.Views.SearchOverlay"
             x:DataType="vm:MainViewModel"
             IsVisible="{Binding IsSearchOpen}"
             Focusable="False">

    <!-- Full-screen backdrop dims everything behind the panel. Click anywhere
         outside the panel to close (handler in code-behind). -->
    <Grid Background="#A0000000" PointerPressed="OnBackdropPressed">

        <!-- Centred panel. 60% of window width, 70% of window height max. -->
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Width="720" MaxHeight="600"
                Background="{DynamicResource SholtoSurfaceRaised}"
                BorderBrush="{DynamicResource SholtoBorder}" BorderThickness="1"
                CornerRadius="8" Padding="0"
                PointerPressed="OnPanelPressed">

            <Grid RowDefinitions="Auto,*" Margin="0">
                <!-- Big search input on top -->
                <TextBox x:Name="QueryBox"
                         Grid.Row="0"
                         Text="{Binding Search.Query, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Watermark="Search artist or title…"
                         FontSize="24" Padding="20,16"
                         BorderThickness="0"
                         Background="Transparent"
                         Foreground="{DynamicResource SholtoTextBright}"
                         KeyDown="OnQueryKeyDown"/>

                <Border Grid.Row="0" VerticalAlignment="Bottom" Height="1"
                        Background="{DynamicResource SholtoBorder}"/>

                <!-- Filtered results -->
                <ListBox Grid.Row="1"
                         x:Name="ResultsList"
                         ItemsSource="{Binding Search.Results}"
                         SelectedIndex="{Binding Search.SelectedIndex, Mode=TwoWay}"
                         Background="Transparent"
                         BorderThickness="0"
                         Focusable="False"
                         Padding="0,4">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:TrackRow">
                            <Grid ColumnDefinitions="*,Auto,60" Margin="12,4">
                                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding Artist}" FontWeight="Bold"
                                               Foreground="{DynamicResource SholtoTextBright}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="—" Foreground="{DynamicResource SholtoTextMuted}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding Title}"
                                               Foreground="{DynamicResource SholtoTextBright}"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding BpmDisplay}"
                                           Foreground="{DynamicResource SholtoAccent}"
                                           Margin="12,0" VerticalAlignment="Center"/>
                                <!-- Camelot chip. Bound to Key (not Camelot — that property
                                     name doesn't exist on TrackRow; the field is called Key
                                     because some tracks have a non-Camelot key string too).
                                     Hidden when the track hasn't been analysed yet so the
                                     chip area collapses cleanly. -->
                                <Border Grid.Column="2" Background="{Binding KeyBrush}"
                                        CornerRadius="3" Padding="6,2"
                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                        IsVisible="{Binding Key, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                    <TextBlock Text="{Binding Key}" FontSize="11" FontWeight="Bold"
                                               Foreground="White"
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>
    </Grid>
</UserControl>
