<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="using:Sholto.App.Controls"
             x:Class="Sholto.App.Views.DeckView"
             x:Name="Root">

    <Grid Background="{DynamicResource SholtoSurfaceRaised}">

        <Panel>
            <controls:WaveformControl Peaks="{Binding Peaks}"
                                      BeatTimes="{Binding BeatTimes}"
                                      DownbeatTimes="{Binding DownbeatTimes}"
                                      PlayPosition="{Binding PlayPosition}"
                                      PlaybackSpeed="{Binding PlaybackSpeed}"
                                      GainOverlay="{Binding EffectiveGain}"
                                      GainOverlayColor="{Binding $parent[Window].DataContext.Theme.MintColor}"
                                      MagneticGlowSec="{Binding MagneticGlowSec}"
                                      IsScrubbing="{Binding IsScrubbing}"
                                      Palette="{Binding $parent[Window].DataContext.WaveformPalette}"/>

            <!-- Fade-to-background over the played half. -->
            <Border HorizontalAlignment="Left" Width="600" IsHitTestVisible="False"
                    Background="{Binding $parent[Window].DataContext.Theme.PlayedFadeGradient}"/>

            <!-- Mute tint: full-deck red wash whenever EffectiveGain is 0 (channel fader
                 fully down or crossfader fully on the other deck). Sits above the
                 waveform but below the disc/title cluster so the indicators stay legible. -->
            <Border IsHitTestVisible="False"
                    Background="#FF3D4E" Opacity="0.18"
                    IsVisible="{Binding IsMuted}"/>

            <!-- Disc + title cluster -->
            <!-- Disc + title cluster sits OVER the waveform. IsHitTestVisible was
                 previously false on this whole panel to let the waveform receive
                 pointer events, but the waveform has no click handlers and the
                 ÷2 / ×2 BPM buttons need to be clickable — so allow hit-test
                 here and let individual decorative children opt out below. -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Left" VerticalAlignment="Center"
                        Margin="20,0,0,0" Spacing="16">

                <StackPanel Orientation="Vertical" Spacing="6">
                <Grid Width="140" Height="140">
                    <!-- Outer ring: colour by progress, opacity flashes near the end. -->
                    <Border Name="DiscRing" Width="140" Height="140">
                        <Ellipse Width="140" Height="140"
                                 Fill="{DynamicResource SholtoBgDeep}"
                                 Stroke="{Binding DiscRingBrush}"
                                 StrokeThickness="3"/>
                    </Border>
                    <Ellipse Width="124" Height="124" Stroke="{DynamicResource SholtoBorder}" StrokeThickness="1"/>
                    <Ellipse Width="108" Height="108" Stroke="{DynamicResource SholtoBorder}" StrokeThickness="1"/>
                    <Ellipse Width="92"  Height="92"  Stroke="{DynamicResource SholtoBorder}" StrokeThickness="1"/>

                    <!-- Needle (behind the album art so only the outer stub pokes out) -->
                    <Border Width="140" Height="140"
                            RenderTransformOrigin="0.5,0.5"
                            Background="Transparent">
                        <Border.RenderTransform>
                            <RotateTransform Angle="{Binding DiscAngle}" CenterX="70" CenterY="70"/>
                        </Border.RenderTransform>
                        <Rectangle Width="2" Height="60"
                                   Fill="{DynamicResource SholtoMint}"
                                   HorizontalAlignment="Center" VerticalAlignment="Top"
                                   Margin="0,10,0,0"/>
                    </Border>

                    <Ellipse Width="80" Height="80"
                             HorizontalAlignment="Center" VerticalAlignment="Center"
                             Fill="{Binding $parent[Window].DataContext.Theme.AlbumArtBrush}"/>

                    <!-- BPM trio centred over the album-art ellipse:
                           original (small, only when tempo-shifted)
                           current  (big main number)
                           range    (small, only when tempo-shifted)
                         Wrapped in a StackPanel so the three lines stay stacked
                         even though they sit inside the disc Grid. -->
                    <!-- BPM stack: main number gets a black drop-shadow halo for an
                         outline effect; smaller original + range numbers get a small
                         dark themed chip so they read against the album-art gradient. -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Spacing="2"
                                IsVisible="{Binding HasBpm}">
                        <StackPanel.Styles>
                            <!-- Side chips: collapsed (opacity 0 + squashed + nudged
                                 toward the centre) when not tempo-shifted, then ease
                                 outward into place when `shifted` class is set. -->
                            <Style Selector="Border.bpm-chip-top">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="RenderTransform" Value="scaleY(0.4) translateY(10px)"/>
                            </Style>
                            <Style Selector="Border.bpm-chip-top.shifted">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="RenderTransform" Value="scaleY(1) translateY(0px)"/>
                            </Style>
                            <Style Selector="Border.bpm-chip-bottom">
                                <Setter Property="Opacity" Value="0"/>
                                <Setter Property="RenderTransform" Value="scaleY(0.4) translateY(-10px)"/>
                            </Style>
                            <Style Selector="Border.bpm-chip-bottom.shifted">
                                <Setter Property="Opacity" Value="1"/>
                                <Setter Property="RenderTransform" Value="scaleY(1) translateY(0px)"/>
                            </Style>
                            <!-- Central number: briefly tilts + slight scale-down when
                                 the deck enters/exits shifted mode, then flattens. -->
                            <Style Selector="Border.bpm-chip-main">
                                <Setter Property="RenderTransform" Value="rotate(0deg) scale(1)"/>
                            </Style>
                            <Style Selector="Border.bpm-chip-main.shifted">
                                <Setter Property="RenderTransform" Value="rotate(0deg) scale(1)"/>
                            </Style>
                        </StackPanel.Styles>

                        <Border Classes="bpm-chip-top" Classes.shifted="{Binding ShowOriginalBpm}"
                                CornerRadius="6" Padding="6,1"
                                Background="{DynamicResource SholtoBgDeep}"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="50%,100%">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.35"/>
                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.45" Easing="CubicEaseInOut"/>
                                </Transitions>
                            </Border.Transitions>
                            <TextBlock Text="{Binding OriginalBpmShort}"
                                       FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource SholtoTextBright}"
                                       Opacity="0.9"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Click the BPM to flip ½ / ×2: left-click halves (most madmom
                             errors are doubled; clicking halves brings it back to truth),
                             right-click doubles. Persisted to SQLite per track. -->
                        <Border Classes="bpm-chip-main" Classes.shifted="{Binding IsTempoShifted}"
                                CornerRadius="6" Padding="8,1"
                                Background="{DynamicResource SholtoBgDeep}"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="50%,50%"
                                Cursor="Hand"
                                ToolTip.Tip="Double / Halve BPM"
                                PointerPressed="OnBpmPressed">
                            <Border.Transitions>
                                <Transitions>
                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.28" Easing="CubicEaseOut"/>
                                </Transitions>
                            </Border.Transitions>
                            <TextBlock Text="{Binding BpmDisplayShort}"
                                       FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource SholtoTextBright}"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <Border Classes="bpm-chip-bottom" Classes.shifted="{Binding ShowOriginalBpm}"
                                CornerRadius="6" Padding="6,1"
                                Background="{DynamicResource SholtoBgDeep}"
                                HorizontalAlignment="Center"
                                RenderTransformOrigin="50%,0%">
                            <Border.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.35"/>
                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.45" Easing="CubicEaseInOut"/>
                                </Transitions>
                            </Border.Transitions>
                            <TextBlock Text="{Binding PitchRangeDisplay}"
                                       FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource SholtoAccent}"
                                       HorizontalAlignment="Center"/>
                        </Border>

                    </StackPanel>

                </Grid>

                <!-- Stem labels below the disc as right-leaning parallelogram chips.
                     Filled-color when the stem is active, hollow + colored text when muted.
                     Mirrors the arcs above; same color codes.
                     Hidden until Demucs stems are ready — the toggles do nothing
                     audibly without stems, so we don't show them as if they did. -->
                <StackPanel Orientation="Horizontal" Spacing="3" HorizontalAlignment="Center"
                            IsVisible="{Binding HasStems}">
                    <Grid Width="42" Height="16">
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Fill="#3D8BFF" Stroke="#3D8BFF" StrokeThickness="1"
                              IsVisible="{Binding DrumsActive}"/>
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Stroke="#3D8BFF" StrokeThickness="1"
                              IsVisible="{Binding !DrumsActive}"/>
                        <TextBlock Text="DRMS" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="Black" IsVisible="{Binding DrumsActive}"/>
                        <TextBlock Text="DRMS" FontSize="9" FontWeight="Bold" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#3D8BFF" IsVisible="{Binding !DrumsActive}"/>
                    </Grid>
                    <Grid Width="42" Height="16">
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Fill="#34F06F" Stroke="#34F06F" StrokeThickness="1"
                              IsVisible="{Binding VocalsActive}"/>
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Stroke="#34F06F" StrokeThickness="1"
                              IsVisible="{Binding !VocalsActive}"/>
                        <TextBlock Text="VOX" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="Black" IsVisible="{Binding VocalsActive}"/>
                        <TextBlock Text="VOX" FontSize="9" FontWeight="Bold" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#34F06F" IsVisible="{Binding !VocalsActive}"/>
                    </Grid>
                    <Grid Width="42" Height="16">
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Fill="#FF4E5E" Stroke="#FF4E5E" StrokeThickness="1"
                              IsVisible="{Binding InstrumentalActive}"/>
                        <Path Data="M 6 0 L 42 0 L 36 16 L 0 16 Z"
                              Stroke="#FF4E5E" StrokeThickness="1"
                              IsVisible="{Binding !InstrumentalActive}"/>
                        <TextBlock Text="INST" FontSize="9" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="Black" IsVisible="{Binding InstrumentalActive}"/>
                        <TextBlock Text="INST" FontSize="9" FontWeight="Bold" Opacity="0.7"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="#FF4E5E" IsVisible="{Binding !InstrumentalActive}"/>
                    </Grid>
                </StackPanel>
                </StackPanel>

                <StackPanel VerticalAlignment="Center" Spacing="4" MaxWidth="320">
                    <TextBlock Text="{Binding LoadedTrack.Title, FallbackValue=''}"
                               FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource SholtoTextBright}"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="{Binding LoadedTrack.Artist, FallbackValue=''}"
                               FontSize="14"
                               Foreground="{DynamicResource SholtoTextMuted}"
                               TextTrimming="CharacterEllipsis"/>
                    <!-- Camelot key chip — Camelot-coloured background so the
                         same hue shows here and in the library row. Hidden until
                         KeyAnalysis lands. Dark text on the saturated chip stays
                         legible across the whole 24-key palette. -->
                    <Border CornerRadius="6" Padding="8,2"
                            Background="{Binding KeyBrush}"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0"
                            IsVisible="{Binding HasKey}">
                        <TextBlock Text="{Binding Camelot}"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Panel>
    </Grid>
</UserControl>
